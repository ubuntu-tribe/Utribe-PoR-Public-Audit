# All defaults are Polygon mainnet. Override only for testnet/staging deploys.
# Public RPC for read-only on-chain calls.
#
# NOTE (2026-05-20): https://polygon-rpc.com began returning HTTP 401 to
# unauthenticated POSTs. The default below is PublicNode's public Polygon
# endpoint, which agrees with dRPC and the audit-doc sanity snapshot on
# block height and GIFT.totalSupply(). Other verified alternatives:
#   - https://polygon.drpc.org                  (dRPC)
#   - https://rpc-mainnet.matic.quiknode.pro    (QuikNode public)
# For production, prefer an authenticated tier (Alchemy / Infura / Ankr).
VITE_RPC_URL=https://polygon-bor-rpc.publicnode.com
VITE_CHAIN_ID=137

# Contract addresses (Polygon mainnet).
VITE_GIFT_TOKEN_ADDRESS=0xCfde7c43EDB3c9f71331AAc1003b099CE40c94ea
VITE_POR_ADDRESS=0xa674f2b838328A5ca29Df5fC2357d20D1AAc785e
VITE_MINT_CONTROLLER_ADDRESS=0xeae4E63F42794952Aa820c30731B1b1f18D6c4C9

# Off-chain event indexer (taas-api). Production URL is TBD.
VITE_TAAS_API_URL=https://api-stage1.utribe.app
